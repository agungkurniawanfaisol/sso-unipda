APP_NAME=UNIPDA-Backend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=unipda
DB_USERNAME=unipda
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

FRONTEND_URL=http://localhost:5173

UNIPDA_OFFICE_API=https://office.universitaspgridelta.ac.id/rest/public/api
UNIPDA_SAINTEK_API=https://saintek.universitaspgridelta.ac.id/backend/public/api
UNIPDA_SAINTEK_PUBLIC=https://saintek.universitaspgridelta.ac.id
UNIPDA_CACHE_TTL=300
UNIPDA_HTTP_TIMEOUT=15

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@unipda.ac.id"
MAIL_FROM_NAME="${APP_NAME}"
