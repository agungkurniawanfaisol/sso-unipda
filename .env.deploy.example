# GitHub Actions Secrets — Hostinger
#
# === DISARANKAN: HTTP deploy (Hostinger blokir FTP dari GitHub Actions) ===
#
# Setup sekali di server (SSH/File Manager):
#   1. Copy scripts/deploy.php → public_html/deploy.php
#   2. Buat token: echo 'GANTI_DENGAN_TOKEN_ACAK_PANJANG' > public_html/.deploy-token
#      chmod 600 public_html/.deploy-token
#
# GitHub Secrets:
#   VITE_API_URL        = https://portal.universitaspgridelta.ac.id/api
#   DEPLOY_HOOK_URL     = https://portal.universitaspgridelta.ac.id/deploy.php
#   DEPLOY_HOOK_TOKEN   = (sama dengan isi .deploy-token)
#
# === Opsional: FTP (jarang jalan dari GitHub Actions) ===
