# GitHub Actions Secrets — Hostinger (FTP, bukan SSH)
#
# Wajib:
#   VITE_API_URL     = https://api.domain-anda.com/api
#   FTP_HOST         = ftp.domain-anda.com  (lihat hPanel → Files → FTP Accounts)
#   FTP_USERNAME     = u278744870
#   FTP_PASSWORD     = password FTP
#   FTP_DIST_DIR     = /domains/domain-anda.com/public_html/frontend/dist/
#                      ^^^ WAJIB diakhiri slash (/) — workflow juga auto-fix jika lupa
#
# Opsional:
#   FTP_PORT         = 21  (default)
#
# Backend auto-deploy (pilih salah satu):
#   HOSTINGER_DEPLOY_WEBHOOK = URL dari hPanel → Advanced → Git → Auto Deployment
#   DEPLOY_HOOK_URL          = https://domain-anda.com/deploy.php
#   DEPLOY_HOOK_TOKEN        = token yang sama dengan DEPLOY_TOKEN di server
