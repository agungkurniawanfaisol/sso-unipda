# GitHub Actions Secrets — Hostinger (FTP/FTPS)
#
# Wajib:
#   VITE_API_URL     = https://api.domain-anda.com/api
#
#   FTP_HOST         = IP server (82.25.96.123) ATAU ftp.domain-anda.com
#                      Pakai IP → FTPS butuh security: loose (sudah di workflow)
#                      Sertifikat Hostinger untuk *.hstgr.io, bukan IP
#
#   FTP_USERNAME     = u278744870  (username FTP, bukan SSH)
#   FTP_PASSWORD     = password FTP (bisa beda dengan password SSH)
#   FTP_DIST_DIR     = /domains/domain-anda.com/public_html/frontend/dist/
#                      ^^^ WAJIB diakhiri slash (/)
#
# Backend auto-deploy (pilih salah satu):
#   HOSTINGER_DEPLOY_WEBHOOK = URL dari hPanel → Advanced → Git → Auto Deployment
#   DEPLOY_HOOK_URL          = https://domain-anda.com/deploy.php
#   DEPLOY_HOOK_TOKEN        = token yang sama dengan .deploy-token di server
